# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/my_money

# Authentication
JWT_SECRET=your-secret-key-change-in-production
INITIAL_PASSWORD=password
# Development only: bypass JWT verification for the configured local user.
# Never enable this in production or when exposing the dev server to untrusted networks.
DEV_BYPASS_AUTH=false
DEV_AUTH_USER_ID=1
DEV_AUTH_USERNAME=zachery

# API Keys
CMC_PRO_API_KEY=your-coinmarketcap-api-key
CG_API_KEY=your-coingecko-api-key

# Plaid (https://dashboard.plaid.com)
PLAID_CLIENT_ID=
PLAID_SECRET=
# 'sandbox' for testing with fake credentials, 'production' for real banks
PLAID_ENV=sandbox

# Google Sheets Export
GOOGLE_SHEETS_ID=your-spreadsheet-id-from-google-sheets-url

# Production-only
# Comma-separated list of allowed frontend origins (required when NODE_ENV=production).
# Example: CORS_ORIGIN=https://my-money.example.com,https://www.my-money.example.com
CORS_ORIGIN=
# Set to "false" on additional scaled instances so cron jobs only run on one worker.
RUN_SCHEDULED_JOBS=true

# Optional comma-separated browser origins allowed to call the authenticated
# remote MCP endpoint. Non-browser MCP clients generally do not send Origin.
MCP_ALLOWED_ORIGINS=
